# Copy to .env — never commit .env (gitignored).

PORT=8787
HOST=127.0.0.1

# Supabase JWT verification. Leave unset for local dev (auth is bypassed with a
# loud warning and user id "dev"). Set at least one before any deploy.
# Modern Supabase projects: https://<ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=
# Legacy HS256 secret (Supabase dashboard → Settings → API → JWT secret)
SUPABASE_JWT_SECRET=

# Cost caps, USD per user per day (§4.3.6). Soft cap flips new roleplays to the
# cheap pipeline; hard cap blocks new non-drill sessions. Active sessions are
# NEVER terminated (R13).
DAILY_SOFT_CAP_USD=2.50
DAILY_HARD_CAP_USD=5.00

# Provider keys — added as each capability is wired up (Phases 2–3).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
ELEVENLABS_API_KEY=
